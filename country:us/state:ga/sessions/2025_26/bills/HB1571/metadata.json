  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend an Act establishing the State Court of Bryan County (formerly the City Court of Pembroke), approved January 10, 1938 (Ga. L. 1937-38, Ex. Sess., p. 714), as amended, particularly by an Act approved April 9, 1996 (Ga. L. 1996, p. 4404), so as to revise the terms of said court; to provide for an effective date; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
  ],
