{
  "legislative_session": "2025_26",
  "identifier": "HB 1087",
  "title": "Disabled Veteran Home Modification Act; enact",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "HANDICAPPED PERSONS",
    "LOCAL GOVERNMENT",
    "MILITARY, EMERGENCY MANAGEMENT, AND VETERANS AFFAIRS",
    "STATE GOVERNMENT"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend Chapter 80 of Title 36 of the Official Code of Georgia Annotated, relating to general provisions regarding provisions applicable to counties and municipal corporations, so as to prohibit counties, municipal corporations, and other governmental entities from charging disabled veterans certain fees related to residential improvements to be made to accommodate such veteran's disability status; to provide a definition; to provide for a short title; to provide for legislative findings; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
  ],
