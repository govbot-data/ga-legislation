  "identifier": "SB 542",
  "title": "Sexual Offenses; clergy members to be charged with certain improper sexual contact offenses; permit",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CRIMES AND OFFENSES (CRIMINAL CODE)",
    "MENTAL HEALTH"
