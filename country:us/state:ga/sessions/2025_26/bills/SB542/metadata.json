  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend Chapter 6 of Title 16 of the Official Code of Georgia Annotated, relating to sexual offenses, so as to permit clergy members to be charged with certain improper sexual contact offenses; to provide for definitions; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
  ],
