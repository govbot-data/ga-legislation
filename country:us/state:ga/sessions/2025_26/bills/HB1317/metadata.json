  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to authorize the governing authority of the City of Fort Oglethorpe to levy an excise tax pursuant to subsection (b) of Code Section 48-13-51 of the O.C.G.A.; to provide procedures, conditions, and limitations; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
