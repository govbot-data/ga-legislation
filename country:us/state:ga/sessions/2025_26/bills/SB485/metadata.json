{
  "legislative_session": "2025_26",
  "identifier": "SB 485",
  "title": "Professional Counselors; applicants for a license in social work enrolled in a master's degree program to take the master's social work licensing examination in their final semester of the program; authorize",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "PROFESSIONS AND BUSINESSES"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend Article 1 of Chapter 10A of Title 43 of the Official Code of Georgia Annotated, relating to examination regarding professional counselors, social workers, and marriage and family therapists, so as to authorize applicants for a license in social work enrolled in a master's degree program to take the master's social work licensing examination in their final semester of the program; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
  ],
