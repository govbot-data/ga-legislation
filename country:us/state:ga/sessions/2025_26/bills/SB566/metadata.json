{
  "legislative_session": "2025_26",
  "identifier": "SB 566",
  "title": "Ad Valorem Taxation of Property; the acceptance of tax digests in the event of a publication error made by a newspaper; provide",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "REVENUE AND TAXATION"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend Chapter 5 of Title 48 of the O.C.G.A., relating to ad valorem taxation of property, so as to provide for the acceptance of tax digests in the event of a publication error made by a newspaper; to revise required information for bills and notices of assessment for ad valorem taxation of property; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
  ],
