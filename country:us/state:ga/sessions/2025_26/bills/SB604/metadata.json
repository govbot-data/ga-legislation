  "subject": [
    "CRIMES AND OFFENSES (CRIMINAL CODE)"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend Title 16 of the Official Code of Georgia Annotated, relating to crimes and offenses, so as to provide the Attorney General concurrent jurisdiction with district attorneys to conduct criminal prosecutions of violent crimes, illegal immigration offenses, and fentanyl offenses; to provide for related matters; to provide for an effective date and applicability; to repeal conflicting laws; and for other purposes."
    }
  ],
