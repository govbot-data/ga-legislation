{
  "legislative_session": "2025_26",
  "identifier": "SB 591",
  "title": "Offenses Against Public Order; the disruption of a religious service; prohibit",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CRIMES AND OFFENSES (CRIMINAL CODE)"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend Article 2 of Chapter 11 of Title 16 of the Official Code of Georgia Annotated, relating to offenses against public order, so as to prohibit the disruption of a religious service; to provide for enhanced penalties; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
  ],
