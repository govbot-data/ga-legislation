  "identifier": "HB 1118",
  "title": "Public officers and employees; 120 hours of maternal birth leave; provide",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "EDUCATION",
    "HEALTH",
    "PUBLIC OFFICERS AND EMPLOYEES"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend Article 1 of Chapter 20 of Title 45 of the Official Code of Georgia Annotated, relating to general provisions relative to personnel administration, so as to provide 80 hours of maternal birth leave; to provide for definitions; to provide rules; to provide for penalties; to provide notice; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
  ],
