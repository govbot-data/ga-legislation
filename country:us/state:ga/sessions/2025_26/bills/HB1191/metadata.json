{
  "legislative_session": "2025_26",
  "identifier": "HB 1191",
  "title": "Motor vehicles; additional military medal awards eligible for special veteran license plates; provide",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "MILITARY, EMERGENCY MANAGEMENT, AND VETERANS AFFAIRS",
    "MOTOR VEHICLES AND TRAFFIC"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL to be entitled an Act to amend Article 3 of Chapter 2 of Title 40 of the Official Code of Georgia Annotated, relating to prestige license plates and special plates for certain persons and vehicles, so as to provide for additional military medal awards eligible for special veteran license plates; to provide for a specialty license plate for United States Navy submarine service members; to provide for related matters; to repeal conflicting laws; and for other purposes."
    }
  ],
